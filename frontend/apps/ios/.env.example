# iOS app environment. Copy to .env; .env is gitignored.
#
# `make env-to-xcconfig` (run by `make bootstrap` and by fastlane before_all)
# writes these into Config/Secrets.xcconfig, which each per-configuration
# xcconfig (Config/Pantopus.{Debug,Staging,Release}.xcconfig) overlays on top
# of its committed defaults. So values here OVERRIDE the per-config defaults
# for whichever configuration you build.
#
# Per-configuration defaults (no .env needed):
#   Debug   → localhost          + pk_test_REPLACE_ME + APNs development
#   Staging → staging.api…app    + pk_test_REPLACE_ME + APNs production
#   Release → api.pantopus.app   + pk_live_REPLACE_ME + APNs production
#
# In the release pipeline, CI writes .env from repository secrets so Release
# resolves the LIVE Stripe key. Locally you typically only need the Stripe
# key (and a LAN IP for physical-device testing).
#
# For simulator-only local dev, localhost works. For physical iPhone testing,
# replace localhost with your Mac's LAN IP from `ipconfig getifaddr en0`
# (for example: http://192.168.1.42:8000). The simulator can also use the LAN
# IP, so one value can cover both.
PANTOPUS_API_BASE_URL=http://localhost:8000
PANTOPUS_SOCKET_URL=http://localhost:8000

# Stripe publishable key. Dev/staging use pk_test_...; the Release pipeline
# must supply pk_live_... via the STRIPE_PUBLISHABLE_KEY CI secret.
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Sentry DSN — leave empty to disable crash reporting locally
# https://sentry.io/settings/[org]/projects/[project]/keys/
SENTRY_DSN=

# Sentry release tooling — only needed for dSYM upload from Fastlane
# (`beta` / `release` lanes). Leave empty and the dSYM upload is skipped.
# Create a token at https://sentry.io/settings/account/api/auth-tokens/
# (scopes: project:releases, project:write).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog product analytics. Leave POSTHOG_API_KEY empty to disable the
# vendor — the app no-ops analytics when it's blank (dev / CI send nothing).
# POSTHOG_HOST defaults to PostHog EU Cloud; set US Cloud
# (https://us.i.posthog.com) or your self-hosted URL as needed.
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# Fastlane Match (shared signing certs/profiles via a private Git repo)
MATCH_GIT_URL=git@github.com:your-org/pantopus-certificates.git
MATCH_PASSWORD=REPLACE_ME

# App Store Connect API key (for TestFlight + App Store uploads)
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
# Base64-encoded .p8 contents OR path to .p8 file
APP_STORE_CONNECT_KEY_CONTENT=

# Apple Developer Team ID (10-char alphanumeric)
APPLE_TEAM_ID=
