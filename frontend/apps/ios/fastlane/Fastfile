# Pantopus iOS — Fastfile
# https://docs.fastlane.tools

default_platform(:ios)

platform :ios do
  before_all do
    xcodegen(spec: "project.yml")
    # XcodeGen (via XcodeProj) defaults to objectVersion 77 in recent
    # builds; Xcode 15.4 in CI can't read 77. Idempotently rewrite the
    # generated pbxproj so older xcodebuild can open the project.
    sh("/usr/bin/sed -i '' -E 's/objectVersion = (6[0-9]|7[0-9]);/objectVersion = 56;/' ../Pantopus.xcodeproj/project.pbxproj")
  end

  desc "Run unit + UI tests on simulator"
  lane :test do
    run_tests(
      project: "Pantopus.xcodeproj",
      scheme: "Pantopus",
      devices: ["iPhone 15"],
      clean: true
    )
  end

  desc "Build and upload to TestFlight (via match for signing)"
  lane :beta do
    setup_ci if is_ci
    match(type: "appstore", readonly: is_ci)

    increment_build_number(
      build_number: latest_testflight_build_number(initial_build_number: 0) + 1
    )

    build_app(
      project: "Pantopus.xcodeproj",
      scheme: "Pantopus",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      xcargs: "PANTOPUS_API_ENV=production"
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: last_git_commit[:message]
    )
  end

  desc "Build, upload metadata + screenshots, and submit to App Store review"
  lane :release do
    setup_ci if is_ci
    match(type: "appstore", readonly: is_ci)

    build_app(
      project: "Pantopus.xcodeproj",
      scheme: "Pantopus",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      xcargs: "PANTOPUS_API_ENV=production"
    )

    # Push every text file under fastlane/metadata/<locale>/ + the
    # PNGs under fastlane/screenshots/ before submitting.
    upload_to_app_store(
      submit_for_review: true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      skip_metadata: false,
      skip_screenshots: false
    )
  end

  desc "Capture App Store screenshots for the 6 hero screens × 3 devices"
  lane :screenshots do
    capture_screenshots(
      project: "Pantopus.xcodeproj",
      scheme: "PantopusUITests",
      output_directory: "./fastlane/screenshots",
      clear_previous_screenshots: true,
      override_status_bar: true,
      stop_after_first_error: false
    )
  end

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception.message}")
  end
end
