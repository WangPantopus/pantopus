<?xml version="1.0" encoding="utf-8"?>
<!-- https://developer.android.com/guide/topics/data/autobackup -->
<full-backup-content>
    <!-- Never back up auth tokens. The legacy v1 DataStore path is retained
         until the one-shot migration in TokenStorage drains and clears it. -->
    <exclude domain="sharedpref" path="secure_auth_tokens.xml" />
    <exclude domain="file" path="datastore/auth_tokens.preferences_pb" />
</full-backup-content>
