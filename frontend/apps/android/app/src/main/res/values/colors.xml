<?xml version="1.0" encoding="utf-8"?>
<!--
  Pantopus design-system color tokens, exposed as Android color resources.

  Mirrors app/src/main/java/app/pantopus/android/ui/theme/Color.kt so that
  status-bar tinting, splash screen drawables, and other non-Compose XML can
  reference the same palette. When you add or rename a token in Color.kt,
  update this file in lock-step.
-->
