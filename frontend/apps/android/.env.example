# Android app environment. Copy to .env; .env is gitignored.
#
# Values here are read by app/build.gradle.kts at configuration time and
# baked into BuildConfig (so the app sees them at runtime without shipping
# a real keystore / secrets file).

# --- Backend ---
# Emulator uses 10.0.2.2 to reach the host machine's localhost.
# Physical device: put your Mac's LAN IP (e.g. http://192.168.1.42:8000).
PANTOPUS_API_BASE_URL=http://10.0.2.2:8000
PANTOPUS_SOCKET_URL=http://10.0.2.2:8000

# --- Stripe ---
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# --- Google Maps ---
# Get a key at https://console.cloud.google.com/google/maps-apis
# Restrict by package name + SHA-1 fingerprint for production.
MAPS_API_KEY=

# --- Observability ---
# Sentry DSN — leave empty to disable crash reporting locally.
# https://sentry.io/settings/[org]/projects/[project]/keys/
SENTRY_DSN=

# Shipped into BuildConfig so Sentry events are tagged by environment.
# One of: local | staging | production
PANTOPUS_ENV=local

# --- Release signing ---
# Required for `./gradlew bundleRelease`. Leave empty in dev.
# PANTOPUS_KEYSTORE_FILE=/absolute/path/to/pantopus.jks
# PANTOPUS_KEYSTORE_PASSWORD=
# PANTOPUS_KEY_ALIAS=pantopus
# PANTOPUS_KEY_PASSWORD=
