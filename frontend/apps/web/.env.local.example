NEXT_PUBLIC_API_URL=http://localhost:8000
# Canonical site URL for share links / metadata. In production, also attach the apex host
# (https://pantopus.com) to this deployment so /.well-known/apple-app-site-association and
# assetlinks.json are reachable on both www and non-www (Universal Links / App Links).
NEXT_PUBLIC_APP_URL=https://www.pantopus.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
