# Supabase Configuration

# Supabase Project Details
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database Connection (Direct PostgreSQL access)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# JWT Secret (used by Supabase Auth)
JWT_SECRET=your-jwt-secret-from-supabase

# App Configuration
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Background jobs
# Set CRON_ENABLED=false on API containers when a separate worker runs node-cron.
# Set PGBOSS_ENABLED=false on API containers when a separate worker runs pg-boss.
# Set LAMBDA_BACKED_CRON_ENABLED=false after EventBridge owns Tier 1 jobs.
CRON_ENABLED=true
PGBOSS_ENABLED=true
LAMBDA_BACKED_CRON_ENABLED=true

# OAuth redirect base URL (defaults to APP_URL if not set)
# Set this to the frontend URL for OAuth callbacks (e.g. https://pantopus.com)
AUTH_REDIRECT_URL=http://localhost:3000
# In production, do not leave APP_URL / AUTH_REDIRECT_URL on localhost.
# Supabase signup and password-reset emails will use these values.
# Example production values:
# APP_URL=https://pantopus.com
# AUTH_REDIRECT_URL=https://pantopus.com

# Apple Sign-In (configured in Supabase Dashboard for production)
# These are set in the Supabase project settings, not here.
# SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=com.pantopus.web  (your Apple Services ID)
# SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=<JWT signed with your Apple private key>

# Email Configuration (Postmark SMTP)
# Use the Postmark server token for both SMTP_USER and SMTP_PASS.
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=your-postmark-server-token
SMTP_PASS=your-postmark-server-token
SMTP_FROM=Pantopus <hello@pantopus.com>
SUPPORT_EMAIL=support@pantopus.com

# Stripe (existing)
STRIPE_SECRET_KEY=your-stripe-secret

# Twilio (existing)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Chat retention policy
# Default redaction window (days) for deleted messages.
CHAT_DELETED_REDACT_DAYS=180
# Optional per-room override map as JSON:
# CHAT_ROOM_RETENTION_DAYS={"room-uuid-1":180,"room-uuid-2":365}
CHAT_ROOM_RETENTION_DAYS={}

# ── Geo / Map Configuration ────────────────────────────────────
# Mapbox access token for server-side geocoding (secret, never expose to client)
MAPBOX_ACCESS_TOKEN=
# Public token embedded in tile URLs (safe for frontend)
NEXT_PUBLIC_MAPBOX_TOKEN=
# Active geo provider (default: mapbox)
GEO_PROVIDER=mapbox

# ── Address Verification Pipeline ──────────────────────────────
# All keys below are OPTIONAL in development. When missing, the
# backend automatically uses mock providers and logs verification
# codes to the console.  In production every key marked [REQUIRED]
# must be set or the server will refuse to start.

# Google Address Validation API (Layer 2 — geocoding + normalization)
# Obtain at https://console.cloud.google.com → APIs → Address Validation
# [REQUIRED in production]
GOOGLE_ADDRESS_VALIDATION_API_KEY=

# Google Places API key (autocomplete widget — frontend-only, not used by backend directly)
# Included here for documentation; the frontend reads NEXT_PUBLIC_GOOGLE_PLACES_API_KEY.
# GOOGLE_PLACES_API_KEY=

# Google Places API key for backend place-classification shadow/enforcement.
# Optional while ENABLE_ADDRESS_PLACE_PROVIDER=false. If omitted, the backend
# falls back to GOOGLE_ADDRESS_VALIDATION_API_KEY for Places requests.
GOOGLE_PLACES_API_KEY=

# Smarty US Street Address API (Layer 3 — DPV / RDI deliverability)
# Obtain at https://www.smarty.com/account/keys
# [REQUIRED in production]
SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=

# ATTOM parcel/property provider (optional until parcel shadow/enforcement is enabled)
ATTOM_API_KEY=
# Log full /property/detail JSON + parsed snapshot to server logs (verbose)
# ATTOM_LOG_RESPONSES=1

# Add Home step 2 — optional LLM tier for property field suggestions (after ATTOM + heuristics).
# Requires OPENAI_API_KEY. Leave unset or not 1 to skip LLM (recommended unless you need gap-fill).
# PROPERTY_SUGGESTIONS_LLM=1
# PROPERTY_SUGGESTIONS_LLM_MODEL=gpt-4o-mini

# Lob API — physical postcard mailing for mail-code verification
# Obtain at https://dashboard.lob.com/settings/api-keys
# [REQUIRED in production]
LOB_API_KEY=
# 'test' or 'live'. Test mode returns immediately without mailing.
LOB_ENV=test
# Webhook secret for verifying Lob delivery event signatures (HMAC-SHA256)
LOB_WEBHOOK_SECRET=

# Lob — return address on postcards (optional, sensible defaults used)
# LOB_FROM_NAME=Pantopus
# LOB_FROM_ADDRESS_LINE1=123 Verification Ln
# LOB_FROM_CITY=San Francisco
# LOB_FROM_STATE=CA
# LOB_FROM_ZIP=94107

# ── Mail Verification Tuning ──────────────────────────────────
# All values below have sensible defaults. Override only when needed.

# How many days a verification code stays valid (default: 30)
MAIL_VERIFY_CODE_EXPIRY_DAYS=30
# Max wrong-code attempts before lockout (default: 5)
MAIL_VERIFY_MAX_ATTEMPTS=5
# Cooldown hours between resends (default: 48)
MAIL_VERIFY_COOLDOWN_HOURS=48
# Max resends per verification attempt (default: 3)
MAIL_VERIFY_MAX_RESENDS=3
# Per-user rate limit: max new verifications within window (default: 2)
MAIL_VERIFY_USER_RATE_LIMIT=2
# Per-user rate window in hours (default: 24)
MAIL_VERIFY_USER_RATE_WINDOW_HOURS=24
# Per-address rate limit: max attempts within window (default: 5)
MAIL_VERIFY_ADDRESS_RATE_LIMIT=5
# Per-address rate window in days (default: 7)
MAIL_VERIFY_ADDRESS_RATE_WINDOW_DAYS=7

# ── Address Validation Cache ──────────────────────────────────
# Smarty results are cached in HomeAddress.validation_raw_response.
# Cache TTL in days (default: 90)
ADDRESS_VERIFY_CACHE_DAYS=90

# ── Address Verification Rollout Flags ──────────────────────
# All of these default to safe/off states in config unless set here.
ENABLE_ADDRESS_VERIFICATION_EVENTS=true
ENABLE_ADDRESS_VERIFICATION_METRICS=true
ENABLE_ADDRESS_PLACE_PROVIDER=false
ENABLE_ADDRESS_PLACE_PROVIDER_BUSINESS_ENFORCEMENT=false
ENABLE_ADDRESS_SECONDARY_PROVIDER=false
ENABLE_ADDRESS_PARCEL_PROVIDER=false
ENABLE_ADDRESS_PARCEL_PROVIDER_CLASSIFICATION_ENFORCEMENT=false
REQUIRE_ADDRESS_ID_FOR_HOME_CREATE=false
ENFORCE_MIXED_USE_STEP_UP=false
ENFORCE_LOW_CONFIDENCE_STEP_UP=false

# ── Household Claim Rollout Flags ─────────────────────────────
HOUSEHOLD_CLAIM_V2_READ_PATHS=false
HOUSEHOLD_CLAIM_PARALLEL_SUBMISSION=false
HOUSEHOLD_CLAIM_INVITE_MERGE=false
HOUSEHOLD_CLAIM_CHALLENGE_FLOW=false
HOUSEHOLD_CLAIM_ADMIN_COMPARE=false
HOUSEHOLD_CLAIM_JOBS_DRY_RUN=true

# ── Address Verification Provider Tuning ────────────────────
ADDRESS_PLACE_PROVIDER_TIMEOUT_MS=1500
ADDRESS_SECONDARY_PROVIDER_TIMEOUT_MS=1500
ADDRESS_PARCEL_PROVIDER=none
ADDRESS_PARCEL_PROVIDER_TIMEOUT_MS=1500
ADDRESS_PARCEL_CACHE_DAYS=30

# ── Safe Outage Fallback ────────────────────────────────────
ENABLE_SAFE_ADDRESS_OUTAGE_FALLBACK=true
ADDRESS_OUTAGE_FALLBACK_MAX_AGE_DAYS=30
ADDRESS_OUTAGE_FALLBACK_MIN_CONFIDENCE=0.8

# ── Address Step-Up Tuning ──────────────────────────────────
# Maximum age for a previously completed mail-code step-up to satisfy
# create-home gating when ENFORCE_MIXED_USE_STEP_UP or
# ENFORCE_LOW_CONFIDENCE_STEP_UP is enabled.
ADDRESS_STEP_UP_MAX_AGE_DAYS=90

# ── Push notifications (native APNs + FCM) ──────────────────
# Migration off Expo to direct APNs (iOS) + FCM (Android).
# See docs/push-native-migration.md. With none of these set, the native
# legs no-op and only the Expo path (if enabled) sends — so dev works
# without credentials.

# Dual-write transition flag: keep the legacy Expo push path live during
# rollout so we can roll back. Set to "false" to send only via APNs/FCM.
PUSH_EXPO_ENABLED=true

# Apple Push Notification service — token-based (.p8) auth.
# From Apple Developer → Certificates, IDs & Profiles → Keys.
APNS_KEY_ID=                       # 10-char Key ID for the .p8 key
APNS_TEAM_ID=                      # Apple Developer Team ID
APNS_BUNDLE_ID=app.pantopus.ios    # app bundle id (used as the APNs topic)
# The .p8 PEM contents. Newlines may be written as literal \n on one line.
APNS_PRIVATE_KEY=
# Alternative to APNS_PRIVATE_KEY: base64 of the raw .p8 file.
# APNS_PRIVATE_KEY_BASE64=
# true → api.push.apple.com (prod), false/unset → api.sandbox.push.apple.com.
APNS_PRODUCTION=false

# Firebase Cloud Messaging — HTTP v1, service-account auth.
# From the Firebase Console → Project settings → Service accounts → the
# generated service-account JSON.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=                  # client_email from the service account
# private_key from the service account. Literal \n on one line is fine.
FCM_PRIVATE_KEY=
# Alternatives to the three fields above (use ONE approach):
# FCM_SERVICE_ACCOUNT_JSON=        # the whole service-account JSON, inline
# GOOGLE_APPLICATION_CREDENTIALS=  # path to the service-account JSON file
