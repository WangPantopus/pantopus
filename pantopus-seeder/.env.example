# Pantopus Community Content Seeder — Environment Variables
# Copy this file to .env and fill in real values for local development.
# On AWS Lambda, these are loaded from AWS Secrets Manager instead.

# Supabase project URL (Settings > API > URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (Settings > API > service_role secret)
# WARNING: This key has full database access. Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Pantopus backend API base URL
PANTOPUS_API_BASE_URL=https://api.pantopus.com

# Curator account credentials (created by scripts/setup_curator_account.py)
CURATOR_EMAIL=curator@pantopus.com
CURATOR_PASSWORD=your-secure-password-here

# Anthropic API key for Claude Haiku (console.anthropic.com > API Keys)
ANTHROPIC_API_KEY=sk-ant-api03-...
